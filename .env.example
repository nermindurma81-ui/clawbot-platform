# ===== ClawBot Platform - Environment Variables =====

# Server
PORT=3000
NODE_ENV=production

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:9110

# Ollama (Local AI)
OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# Supabase (Auth & Database)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# GitHub Auto-Sync
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=your-username/clawbot-platform
GITHUB_AUTO_SYNC=true

# Railway
RAILWAY_TOKEN=your-railway-token
RAILWAY_SERVICE_ID=your-service-id

# Bot Config
BOT_NAME=ClawBot
BOT_SYSTEM_PROMPT="You are ClawBot, a helpful AI assistant powered by Ollama. Be concise, helpful, and have a bit of personality."
